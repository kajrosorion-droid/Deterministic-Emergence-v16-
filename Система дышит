def stable_hash(*args):
    h = hashlib.sha256(str(args).encode()).hexdigest()
    return int(h[:8], 16)


def sh_range(n, *args):
    return stable_hash(*args) % n


SEASONS = ['spring', 'summer', 'autumn', 'winter']
SEASON_LENGTH = 1000


def get_season(step):
    return SEASONS[(step // SEASON_LENGTH) % 4]


